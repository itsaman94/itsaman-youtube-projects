# ----------------------------------------------------------------------
# 1. Copy this file and rename the copy to ".env"
# 2. Paste your real OpenAI API key below
# 3. Never commit your real .env file to GitHub (it's in .gitignore)
# ----------------------------------------------------------------------

# Your OpenAI API key (get one at https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-key-here

# Optional: which model to use (default is the cheap + fast gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

